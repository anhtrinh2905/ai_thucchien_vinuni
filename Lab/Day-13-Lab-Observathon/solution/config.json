{
  "provider": "openai",
  "model": "gpt-5.4-nano",
  "prompt_file": "solution/prompt.txt",
  "examples_file": "solution/examples.json",
  "model_price_tier": "standard",
  "max_steps": 10,
  "loop_guard": true,
  "temperature": 0.2,
  "context_size": 6,
  "verbose_system": false,
  "timeout_ms": 30000,
  "max_completion_tokens": 800,
  "retry": {"enabled": true, "max_attempts": 3, "backoff_ms": 200},
  "cache": {"enabled": true},
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 6,
  "tool_error_rate": 0.18,
  "catalog_override": {},
  "route_rules": [],
  "planner": true,
  "verify": true,
  "self_consistency": 2,
  "tool_budget": 4
}
